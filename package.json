{
  "name": "oasisic-note-version-control",
  "version": "0.1.0",
  "description": "Git-style version snapshots for Obsidian Markdown files.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production"
  },
  "keywords": [
    "obsidian",
    "version-control",
    "markdown",
    "history"
  ],
  "author": "Hawaiine",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.30",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.20.2",
    "obsidian": "^1.5.12",
    "typescript": "^5.4.3"
  }
}
